{
  "compilerOptions": {
    "module": "ESNext",
    "target": "ES2022",
    "moduleResolution": "node",
    "allowJs": true,
    "checkJs": false,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "lib": ["ES2022"]
  },
  "include": [
    "src/**/*.js",
    "bin/**/*.js",
    "test/**/*.js",
    ".claude/hooks/**/*.mjs"
  ],
  "exclude": [
    "node_modules",
    "**/*.html"
  ]
}
